# macOS
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Files that might appear on external disk
.Spotlight-V100
.Trashes

# Temporary files
*.tmp
*.temp
*.swp
*~

# IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Node (if you add any JS build tools later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Logs
*.log

# Generated presentations (keep folder, ignore content)
final_slides/*
!final_slides/.gitkeep

# User scripts (keep folder, ignore content so users add their own)
scripts/*

# User assets (keep folder, ignore content)
assets/*